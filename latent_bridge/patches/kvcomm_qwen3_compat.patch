+def _match_kv_shape(
+    tensor: torch.Tensor,
+    target_num_kv_heads: int,
+    target_head_dim: int,
+) -> torch.Tensor:
+    current_num_kv_heads = int(tensor.shape[1])
+    if current_num_kv_heads == target_num_kv_heads:
+        aligned = tensor
+    elif target_num_kv_heads % current_num_kv_heads == 0:
+        repeat_factor = target_num_kv_heads // current_num_kv_heads
+        aligned = tensor.repeat_interleave(repeat_factor, dim=1)
+    elif current_num_kv_heads % target_num_kv_heads == 0:
+        group_size = current_num_kv_heads // target_num_kv_heads
+        new_shape = (
+            tensor.shape[0],
+            target_num_kv_heads,
+            group_size,
+            tensor.shape[2],
+            tensor.shape[3],
+        )
+        aligned = tensor.view(new_shape).mean(dim=2)
+    else:
+        index = torch.linspace(
+            0,
+            current_num_kv_heads - 1,
+            steps=target_num_kv_heads,
+            device=tensor.device,
+        ).round().long()
+        aligned = tensor.index_select(1, index)
+
+    current_head_dim = int(aligned.shape[-1])
+    if current_head_dim == target_head_dim:
+        return aligned
+    if target_head_dim % current_head_dim == 0:
+        repeat_factor = target_head_dim // current_head_dim
+        return aligned.repeat_interleave(repeat_factor, dim=-1)
+    if current_head_dim % target_head_dim == 0:
+        group_size = current_head_dim // target_head_dim
+        new_shape = (
+            aligned.shape[0],
+            aligned.shape[1],
+            aligned.shape[2],
+            target_head_dim,
+            group_size,
+        )
+        return aligned.view(new_shape).mean(dim=-1)
+    index = torch.linspace(
+        0,
+        current_head_dim - 1,
+        steps=target_head_dim,
+        device=aligned.device,
+    ).round().long()
+    return aligned.index_select(-1, index)
+
